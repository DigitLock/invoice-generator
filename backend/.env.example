# Server
SERVER_PORT=8081                          # HTTP server port
SERVER_READ_TIMEOUT=15                    # Request read timeout (seconds)
SERVER_WRITE_TIMEOUT=15                   # Response write timeout (seconds)
CORS_ALLOWED_ORIGINS=http://localhost:5173 # Comma-separated allowed origins

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=invoice_generator
DB_SSLMODE=disable                        # disable, require, verify-full

# JWT (shared with Expense Tracker)
JWT_SECRET=change-me-in-production        # Must match Expense Tracker's SECRET_KEY
