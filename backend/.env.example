# Server
# HTTP server port
SERVER_PORT=8081
# Request read timeout (seconds)
SERVER_READ_TIMEOUT=15
# Response write timeout (seconds)
SERVER_WRITE_TIMEOUT=15
# Comma-separated allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=invoice_generator
# Options: disable, require, verify-full
DB_SSLMODE=disable

# JWT (shared with Expense Tracker)
# Must match Expense Tracker's SECRET_KEY
JWT_SECRET=change-me-in-production
